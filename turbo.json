{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      // Turbo 2's default envMode is "strict": child processes (and the cache
      // key) only see env vars declared here. Without this, `next build`
      // silently ran with these unset — the Next.js rewrite proxy target and
      // all NEXT_PUBLIC_* client vars were baked in empty/default instead of
      // the real build-arg values (found while validating the web Dockerfile).
      "env": [
        "API_INTERNAL_URL",
        "NEXT_PUBLIC_API_BASE_URL",
        "NEXT_PUBLIC_QDRANT_DASHBOARD_URL",
        "NEXT_PUBLIC_GRAFANA_URL",
        "NEXT_PUBLIC_JAEGER_URL",
        "NEXT_PUBLIC_DEV_TENANT_ID",
        "NEXT_PUBLIC_DEV_AUTH_TOKEN"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "type-check": {
      "outputs": []
    }
  }
}
