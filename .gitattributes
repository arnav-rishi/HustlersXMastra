# Normalize text files to LF in the repository regardless of platform.
# Without this, Windows checkouts with core.autocrlf unset can make every
# file in the repo appear modified (CRLF vs LF), as seen in this session.
* text=auto eol=lf

# Explicitly mark binary types so they're never subject to EOL conversion.
*.pdf binary
*.docx binary
*.doc binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pem binary
*.zst binary
