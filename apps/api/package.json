{
  "name": "@lexguard/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@lexguard/shared": "workspace:*",
    "@lexguard/agents": "workspace:*",
    "@lexguard/workflows": "workspace:*",
    "@lexguard/observability": "workspace:*",
    "@lexguard/qdrant": "workspace:*",
    "@mastra/core": "^0.10.0",
    "@prisma/client": "^5.15.0",
    "@opentelemetry/auto-instrumentations-node": "^0.47.0",
    "express": "^4.19.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "multer": "^1.4.5-lts.1",
    "jsonwebtoken": "^9.0.2",
    "ioredis": "^5.4.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/multer": "^1.4.11",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/uuid": "^10.0.0",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "prisma": "^5.15.0",
    "typescript": "^5.4.5",
    "tsx": "^4.15.0",
    "supertest": "^7.1.1",
    "vitest": "^2.1.9"
  }
}
