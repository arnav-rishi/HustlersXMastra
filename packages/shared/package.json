{
  "name": "@lexguard/shared",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./schemas": { "types": "./dist/schemas/index.d.ts", "development": "./src/schemas/index.ts", "default": "./dist/schemas/index.js" },
    "./env": { "types": "./dist/env.d.ts", "development": "./src/env.ts", "default": "./dist/env.js" },
