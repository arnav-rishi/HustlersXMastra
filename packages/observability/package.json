{
  "name": "@lexguard/observability",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./tracer": { "types": "./dist/tracer.d.ts", "development": "./src/tracer.ts", "default": "./dist/tracer.js" },
    "./metrics": { "types": "./dist/metrics.d.ts", "development": "./src/metrics.ts", "default": "./dist/metrics.js" }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^1.25.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/sdk-metrics": "^1.25.0",
    "@opentelemetry/sdk-trace-node": "^1.25.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/semantic-conventions": "^1.25.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.52.0",
    "@lexguard/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
