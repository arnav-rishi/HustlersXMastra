    "./classification-agent": { "types": "./dist/classification-agent.d.ts", "development": "./src/classification-agent.ts", "default": "./dist/classification-agent.js" },
    "./retrieval-agent": { "types": "./dist/retrieval-agent.d.ts", "development": "./src/retrieval-agent.ts", "default": "./dist/retrieval-agent.js" },
    "./risk-agent": { "types": "./dist/risk-agent.d.ts", "development": "./src/risk-agent.ts", "default": "./dist/risk-agent.js" },
    "./benchmark-agent": { "types": "./dist/benchmark-agent.d.ts", "development": "./src/benchmark-agent.ts", "default": "./dist/benchmark-agent.js" },
    "./rewrite-agent": { "types": "./dist/rewrite-agent.d.ts", "development": "./src/rewrite-agent.ts", "default": "./dist/rewrite-agent.js" },
