{
  "name": "@lexguard/qdrant",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./client": { "types": "./dist/client.d.ts", "development": "./src/client.ts", "default": "./dist/client.js" },
    "./collections": { "types": "./dist/collections.d.ts", "development": "./src/collections.ts", "default": "./dist/collections.js" },
    "./init": { "types": "./dist/init.d.ts", "development": "./src/init.ts", "default": "./dist/init.js" }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "init": "tsx src/init.ts"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.10.0",
    "@lexguard/shared": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsx": "^4.15.0"
  }
}
