# ==============================================================================
# LexGuard AI — Environment Variables
# Copy this to .env.local and fill in real values.
# NEVER commit .env.local to source control.
# All secrets MUST be fetched from HashiCorp Vault in production.
# ==============================================================================

# --- Node ---
NODE_ENV=development

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=...                       # Azure OpenAI resource key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
# Main/reasoning tier — risk, compliance, parsing, qa, benchmark agents.
# Use your strongest deployed model here (e.g. a gpt-5.4 or gpt-5 deployment name).
AZURE_OPENAI_DEPLOYMENT=...
# Light tier — document, classification, embedding, evaluation, memory,
# retrieval, rewrite, reporting agents. A cheaper/faster model (e.g. gpt-5-nano)
# is a good fit for these; falls back to AZURE_OPENAI_DEPLOYMENT if unset.
AZURE_OPENAI_DEPLOYMENT_MINI=...
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=...          # e.g. text-embedding-3-large

# --- Mastra ---
MASTRA_API_KEY=...                             # Mastra platform access key
MASTRA_PROJECT_ID=...                          # Mastra project ID

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=...                             # required for Qdrant Cloud

# --- PostgreSQL (Prisma) ---
DATABASE_URL=postgresql://lexguard:password@localhost:5432/lexguard_db?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=lexguard-contracts
KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789:key/...

# --- Enkrypt AI (docs.enkryptai.com Guardrails REST API) ---
ENKRYPT_API_KEY=...
ENKRYPT_API_URL=https://api.enkryptai.com
# Measured real-world latency: 330ms-4s+, with cold-start variance. A lower
# timeout aborts real calls and silently falls back to local heuristics.
ENKRYPT_TIMEOUT_MS=8000

# --- LexisNexis ---
LEXISNEXIS_CLIENT_ID=...
LEXISNEXIS_CLIENT_SECRET=...
LEXISNEXIS_AUTH_URL=https://auth.lexisnexis.com/oauth/token
LEXISNEXIS_API_URL=https://api.lexisnexis.com

# --- JWT ---
JWT_RS256_PRIVATE_KEY_PATH=./keys/private.pem
JWT_RS256_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ISSUER=https://api.lexguard.ai
JWT_AUDIENCE=lexguard-api
JWT_TOKEN_TTL=3600

# --- API ---
API_PORT=4000
API_HOST=0.0.0.0
LEXGUARD_DEV_BYPASS_AUTH=false
# Comma-separated browser origins allowed to call the API directly (CORS).
# Leave unset in production — apps/web proxies /api/v1/* server-side via
# next.config.mjs rewrites (API_INTERNAL_URL below), so the browser never
# crosses origins for the primary app. Only needed for direct callers
# (Mastra Studio, scripts, a future mobile app).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Web (apps/web) ---
# Server-side-only: where apps/web's Next.js server proxies /api/v1/* to.
# In Azure this is the api Container App's internal FQDN; in local dev it's
# the api server on localhost.
API_INTERNAL_URL=http://localhost:4000
# Browser-facing base URL used by fetch() calls in apps/web. Set to "" in
# production so requests stay relative (same-origin) and get proxied via
# API_INTERNAL_URL above instead of the browser calling the API directly.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_QDRANT_DASHBOARD_URL=http://localhost:6333/dashboard
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001
NEXT_PUBLIC_JAEGER_URL=http://localhost:16686
NEXT_PUBLIC_DEV_TENANT_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_DEV_AUTH_TOKEN=test

# --- OpenTelemetry ---
OTEL_SERVICE_NAME=lexguard-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT_RPM=100

# --- Feature Flags ---
ENKRYPT_ENABLED=true
LEXISNEXIS_ENABLED=true
HITL_ENABLED=true
