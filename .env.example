# ==============================================================================
# LexGuard AI — Environment Variables
# Copy this to .env.local and fill in real values.
# NEVER commit .env.local to source control.
# All secrets MUST be fetched from HashiCorp Vault in production.
# ==============================================================================

# --- Node ---
NODE_ENV=development

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=...                       # Azure OpenAI resource key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- Mastra ---
MASTRA_API_KEY=...                             # Mastra platform access key
MASTRA_PROJECT_ID=...                          # Mastra project ID

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=...                             # required for Qdrant Cloud

# --- PostgreSQL (Prisma) ---
DATABASE_URL=postgresql://lexguard:password@localhost:5432/lexguard_db?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=lexguard-contracts
KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789:key/...

# --- Enkrypt AI ---
ENKRYPT_API_KEY=...
ENKRYPT_API_URL=https://api.enkrypt.ai/v1

# --- LexisNexis ---
LEXISNEXIS_CLIENT_ID=...
LEXISNEXIS_CLIENT_SECRET=...
LEXISNEXIS_AUTH_URL=https://auth.lexisnexis.com/oauth/token
LEXISNEXIS_API_URL=https://api.lexisnexis.com

# --- JWT ---
JWT_RS256_PRIVATE_KEY_PATH=./keys/private.pem
JWT_RS256_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ISSUER=https://api.lexguard.ai
JWT_AUDIENCE=lexguard-api
JWT_TOKEN_TTL=3600

# --- API ---
API_PORT=4000
API_HOST=0.0.0.0

# --- OpenTelemetry ---
OTEL_SERVICE_NAME=lexguard-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT_RPM=100

# --- Feature Flags ---
ENKRYPT_ENABLED=true
LEXISNEXIS_ENABLED=true
HITL_ENABLED=true
